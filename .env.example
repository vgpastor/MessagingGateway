# Gateway
PORT=3000
NODE_ENV=production
LOG_LEVEL=info

# Path to accounts YAML config (default: config/accounts.yaml)
# ACCOUNTS_CONFIG_PATH=/app/config/accounts.yaml

# Webhook callback (where unified envelopes are forwarded)
WEBHOOK_CALLBACK_URL=https://n8n.yourdomain.com/webhook/umg-inbound
WEBHOOK_CALLBACK_SECRET=your-secret-for-signing

# WhatsApp - wwebjs-api instances
WWEBJS_SAMUR_API_KEY=api-key-samur
WWEBJS_PATROLTECH_API_KEY=api-key-patroltech
WWEBJS_GLOBALEMERG_API_KEY=api-key-globalemerg

# Telegram bots
TG_DEAMAP_ALERTS_TOKEN=123456:ABC-xyz...
TG_PATROLTECH_BOT_TOKEN=789012:DEF-abc...

# Brevo (shared across multiple email accounts)
BREVO_MAIN_API_KEY=xkeysib-...

# AWS SES
SES_ACCESS_KEY_ID=AKIA...
SES_SECRET_ACCESS_KEY=...
SES_REGION=eu-west-1

# Twilio
TWILIO_ALERTS_ACCOUNT_SID=AC...
TWILIO_ALERTS_AUTH_TOKEN=...

# MessageBird
MESSAGEBIRD_PATROL_API_KEY=...
