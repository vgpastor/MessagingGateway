{
  "name": "unified-messaging-gateway",
  "version": "0.3.0",
  "description": "Unified Messaging Gateway - Single point of contact for all messaging integrations",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && npm run build:copy-migrations",
    "build:copy-migrations": "node -e \"const{cpSync}=require('fs');cpSync('src/persistence/migrations/scripts','dist/persistence/migrations/scripts',{recursive:true})\"",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "openapi:export": "tsx scripts/export-openapi.ts",
    "sdk:generate": "npm run openapi:export && cd packages/sdk && npm run generate && node ../../scripts/fix-generated-imports.js",
    "sdk:build": "cd packages/sdk && npm run build"
  },
  "keywords": [
    "messaging",
    "gateway",
    "whatsapp",
    "telegram",
    "email",
    "sms"
  ],
  "engines": {
    "node": ">=20"
  },
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@fastify/websocket": "^11.2.0",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "better-sqlite3": "^12.8.0",
    "dotenv": "^17.3.1",
    "fastify": "^5.8.5",
    "pg": "^8.20.0",
    "prom-client": "^15.1.3",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.3.2",
    "@types/pg": "^8.20.0",
    "orval": "^7.13.2",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
