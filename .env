# Gateway
PORT=3000
NODE_ENV=production
LOG_LEVEL=info

# API authentication (REQUIRED — gateway will not start without it)
# In development (NODE_ENV=development), a default key is used if not set.
# In production, you MUST set a unique key or the server will refuse to start.
# API_KEY=your-strong-unique-secret

# Path to accounts YAML config (inside the data volume)
# ACCOUNTS_CONFIG_PATH=/app/data/accounts.yaml

# Webhook callback (where unified envelopes are forwarded)
# WEBHOOK_CALLBACK_URL=
# WEBHOOK_CALLBACK_SECRET=

# Health check interval in milliseconds (default: 5 minutes)
# HEALTH_CHECK_INTERVAL_MS=300000

# Message persistence (optional — stores all messages in SQLite)
# STORAGE_ENABLED=true
# DATABASE_PATH=data/messages.db
